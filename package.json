{
  "name": "cypress-saucedemo",
  "version": "1.0.0",
  "description": "Cypress E2E test with Mochawesome reporter",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "test": "cypress run --env environment=dev",
    "test:dev": "cypress run --env environment=dev",
    "test:staging": "cypress run --env environment=staging",
    "test:prod": "cypress run --env environment=prod",
    "test:login": "cypress run --spec cypress/e2e/login.cy.ts",
    "clean:reports": "node -e \"require('fs').rmSync('reports/mochawesome',{recursive:true,force:true})\"",
    "report:merge": "mochawesome-merge \"reports/mochawesome/*.json\" > reports/mochawesome/report.json",
    "report:generate": "marge reports/mochawesome/report.json --reportDir reports/mochawesome --inline",
    "test:report": "npm run clean:reports && npm test && npm run report:merge && npm run report:generate"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "cypress": "15.8.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^5.0.0",
    "mochawesome-report-generator": "^6.2.0",
    "typescript": "^6.0.3"
  }
}
