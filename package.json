{
  "name": "cypress-saucedemo",
  "version": "1.0.0",
  "description": "Cypress E2E test with Mochawesome reporter",
  "main": "index.js",
  "scripts": {
    "test": "cypress run",
    "merge-reports": "npx mochawesome-merge reports/mochawesome/*.json > reports/mochawesome/report.json",
    "generate-report": "npx marge reports/mochawesome/report.json --reportDir reports/mochawesome --inline",
    "test:report": "npm run test && npm run merge-reports && npm run generate-report",
    "test:login": "cypress run --spec cypress/e2e/login.cy.js"
  },
  "devDependencies": {
    "cypress": "^15.1.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^5.0.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}
